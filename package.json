{
    "name": "academic-pdf-viewer",
    "displayName": "Academic PDF Viewer",
    "description": "A VS Code PDF reader for academic papers.",
    "version": "1.0.1",
    "icon": "image/icon.png",
    "publisher": "ovolab-veritas",
    "repository": {
        "type": "git",
        "url": "https://github.com/VeriTas-arch/academic-pdf-viewer"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.125.0"
    },
    "categories": [
        "Visualization",
        "Other"
    ],
    "keywords": [
        "pdf",
        "academic",
        "citation",
        "reader",
        "viewer"
    ],
    "galleryBanner": {
        "color": "#111827",
        "theme": "dark"
    },
    "main": "./out/extension.js",
    "contributes": {
        "customEditors": [
            {
                "viewType": "academicPdfViewer.pdf",
                "displayName": "Academic PDF Viewer",
                "selector": [
                    {
                        "filenamePattern": "*.pdf"
                    }
                ],
                "priority": "default"
            }
        ],
        "commands": [
            {
                "command": "academicPdfViewer.navigateBack",
                "title": "PDF: Navigate Back"
            },
            {
                "command": "academicPdfViewer.navigateForward",
                "title": "PDF: Navigate Forward"
            }
        ],
        "keybindings": [
            {
                "command": "academicPdfViewer.navigateBack",
                "key": "alt+left",
                "when": "activeCustomEditorId == academicPdfViewer.pdf"
            },
            {
                "command": "academicPdfViewer.navigateForward",
                "key": "alt+right",
                "when": "activeCustomEditorId == academicPdfViewer.pdf"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "npm run compile:extension && npm run compile:webview",
        "compile:extension": "tsc -p ./",
        "compile:webview": "tsc -p ./tsconfig.webview.json",
        "lint": "eslint \"src/**/*.ts\""
    },
    "devDependencies": {
        "@types/node": "24.x",
        "@types/vscode": "^1.125.0",
        "eslint": "^10.5.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1"
    }
}
